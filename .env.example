# worldquant-harness Environment Configuration
# Copy this file to .env and fill in your values

# LLM — DeepSeek (OpenAI-compatible)
# Optional: leave empty to use expression-only mode (no natural language input)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Database — SQLite (default, zero config) or PostgreSQL
# Leave empty for SQLite (./worldquant_harness.db), or set PostgreSQL URL:
# DATABASE_URL=postgresql+asyncpg://worldquant_harness:your_password@localhost:5433/worldquant_harness
DATABASE_URL=

# Local Development Mode
# Set to true to disable authentication (no login required, no SMTP needed)
# WARNING: Never enable in production!
AUTH_DISABLED=true

# JWT Authentication (not needed if AUTH_DISABLED=true)
JWT_SECRET_KEY=generate_a_random_64_char_hex_string
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP — Email verification codes
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=your_email@example.com
SMTP_USE_TLS=true

# Feedback Webhook (optional, Feishu/Lark)
WORLDQUANT_HARNESS_FEEDBACK_WEBHOOK=
WORLDQUANT_HARNESS_FEEDBACK_WEBHOOK_SECRET=

# RiceQuant (rqdatac) — primary A-share data source (optional)
RQDATAC_USERNAME=
RQDATAC_PASSWORD=

# Admin
WORLDQUANT_HARNESS_ADMIN_PASSWORD=change_this_password

# App tuning (optional)
WORLDQUANT_HARNESS_MAX_ACTIVE_TASKS=100
WORLDQUANT_HARNESS_RATE_LIMIT=50
WORLDQUANT_HARNESS_CORS_ORIGINS=http://localhost:5173,http://localhost:8002

# Task execution backend: "process" (default, multi-core) or "celery" (distributed) or "thread" (legacy)
WORLDQUANT_HARNESS_TASK_BACKEND=process
WORLDQUANT_HARNESS_WORKER_PROCESSES=4

# Rust engine: set to 0 to disable (falls back to pure Python)
WORLDQUANT_HARNESS_RUST_ENGINE=1

# WorldQuant BRAIN API (optional — enables real WQ alpha submission)
WQ_BRAIN_EMAIL=
WQ_BRAIN_PASSWORD=

# Local Wind Oracle data source (optional)
# Enable Wind as the first local A-share source; public baostock/rqdatac remain fallback.
# WORLDQUANT_HARNESS_DATA_SOURCE=wind,baostock
# WORLDQUANT_HARNESS_USE_WIND=1
# Optional: reuse a local config file that exposes CONN_PARAMS and _ORA_CLIENT_DIR.
# WORLDQUANT_HARNESS_WIND_CONFIG_PATH=/path/to/local/wind_mcp_server.py
# Or set explicit connection parameters instead of using WORLDQUANT_HARNESS_WIND_CONFIG_PATH.
# WORLDQUANT_HARNESS_WIND_DB_USER=
# WORLDQUANT_HARNESS_WIND_DB_PASSWORD=
# WORLDQUANT_HARNESS_WIND_DB_DSN=host:1521/service
# WORLDQUANT_HARNESS_WIND_DB_ENCODING=UTF-16
# WORLDQUANT_HARNESS_ORACLE_CLIENT_DIR=D:/oracle/instantclient_23_8

# Celery (only needed if WORLDQUANT_HARNESS_TASK_BACKEND=celery)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
